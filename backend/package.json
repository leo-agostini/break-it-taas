{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "start": "bun run dist/src/index.js",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^16.5.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.14.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "bun-types": "^1.2.13",
    "typescript": "^5.8.3"
  }
}
