{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "worker:dev": "bun --watch src/worker.ts",
    "test": "bun build && bun test ./src/tests",
    "test:integration:k3s": "RUN_K3S_INTEGRATION=1 bun test ./src/tests/integration",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "start": "bun run dist/src/index.js",
    "worker:start": "bun run dist/src/worker.js",
    "migrate:latest": "bun run src/infra/db/migrate.ts up",
    "migrate:rollback": "bun run src/infra/db/migrate.ts down",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@elysiajs/swagger": "^1.3.1",
    "@kubernetes/client-node": "^1.4.0",
    "argon2": "^0.44.0",
    "dotenv": "^16.5.0",
    "elysia": "^1.1.21",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "bun-types": "^1.2.13",
    "typescript": "^5.8.3"
  }
}
