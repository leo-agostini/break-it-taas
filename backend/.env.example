NODE_ENV=development
PORT=3001

# ── Auth (required) ───────────────────────────────────────────────────────────
JWT_SECRET=replace-this-secret
JWT_REFRESH_SECRET=replace-this-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
# COOKIE_DOMAIN=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=*

# ── Database ──────────────────────────────────────────────────────────────────
# docker-compose: postgres://postgres:postgres@postgres:5432/app
# k3s in-cluster: postgres://postgres:postgres@postgres.data.svc.cluster.local:5432/app
# hybrid dev: localhost:5432 should be a kubectl port-forward to svc/postgres.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

# ── Integration tests ─────────────────────────────────────────────────────────
# Defaults match hybrid dev mode (local API + k3d cluster).
# Override to point at a full in-cluster deployment.
RUN_K3S_INTEGRATION=1
INTEGRATION_BASE_URL=http://localhost:3001
INTEGRATION_DB_NAME=app
INTEGRATION_DB_USER=postgres
INTEGRATION_KUBECONFIG_CONTEXT=k3d-workload
INTEGRATION_DB_NAMESPACE=data
INTEGRATION_DB_STATEFULSET=postgres

# ── Runner / k3s (required) ───────────────────────────────────────────────────
RUNNER_SHARED_SECRET=replace-this-runner-secret

# URL the k6 runner pod uses to POST results back to the API.
# • Pure local dev (no k3s):    http://localhost:3001
# • Hybrid dev (local API + k3d jobs): runner pods run inside Docker and cannot
#   reach localhost — use an address reachable from a k3d pod instead:
#   kubectl --context k3d-workload -n app run callback-probe --rm -i \
#     --restart=Never --image=curlimages/curl:8.10.1 -- \
#     curl -sS http://<host-ip>:3001/api/health
# • k3s in-cluster:             http://backend.app.svc.cluster.local
RUNNER_CALLBACK_BASE_URL=http://<host-ip-reachable-from-k3d>:3001

RUNNER_IMAGE=breakit-k6-runner:local
K3S_NAMESPACE=app
KUBERNETES_CONTEXT=k3d-workload
